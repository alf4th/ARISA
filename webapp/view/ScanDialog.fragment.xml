<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        id="scanDialog"
        title="Scan Delivery Barcode"
        contentWidth="420px"
        afterClose=".onScanDialogClose"
    >
        <content>
            <VBox id="scanRootVBox" class="sapUiSmallMargin" alignItems="Center">

                <Text id="scanStatusText" text="Starting camera... point at barcode to scan automatically." class="sapUiSmallMarginBottom" />

                <!-- Camera preview area -->
                <VBox id="cameraPreviewBox" visible="true" width="100%" class="sapUiSmallMarginBottom">
                    <core:HTML id="cameraHtml" content="&lt;div id='scanCameraContainer' style='text-align:center;'&gt;&lt;/div&gt;" />
                </VBox>

                <!-- Manual input fallback -->
                <VBox id="manualInputBox" visible="false" width="100%">
                    <Label id="lblManualBarcode" text="Container Number / Barcode:" class="sapUiSmallMarginBottom" />
                    <Input
                        id="manualBarcodeInput"
                        placeholder="e.g. EXT-DELIV-001"
                        width="100%"
                        submit=".onManualBarcodeSubmit"
                    />
                </VBox>

            </VBox>
        </content>
        <buttons>
            <Button id="btnManualInput" text="Manual Input" press=".onShowManualInput" type="Default" />
            <Button id="btnScanCancel" text="Cancel"        press=".onScanCancel"      type="Default" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>