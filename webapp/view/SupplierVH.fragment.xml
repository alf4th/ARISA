<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <SelectDialog
        id="supplierVHDialog"
        title="Select Supplier (EMKL)"
        search=".onSupplierVHSearch"
        confirm=".onSupplierVHConfirm"
        cancel=".onSupplierVHClose"
        items="{supplierVH>/items}"
        noDataText="No suppliers found"
    >
        <StandardListItem
            title="{supplierVH>Supplier}"
            description="{supplierVH>SupplierName}"
            type="Active"
        />
    </SelectDialog>
</core:FragmentDefinition>
